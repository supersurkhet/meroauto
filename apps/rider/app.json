{
  "expo": {
    "name": "MeroAuto Rider",
    "slug": "meroauto-rider",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "meroauto-rider",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.meroauto.rider",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to find nearby autos and track your ride.",
        "NSLocationAlwaysUsageDescription": "We need your location to track your ride in the background.",
        "NSCameraUsageDescription": "We need camera access to scan auto QR codes for instant rides."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.meroauto.rider",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow MeroAuto to access your camera to scan QR codes."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow MeroAuto to use your location to find nearby autos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
